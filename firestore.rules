rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Globally permit all operations for debugging and initialization.
    // This will help identify if the collection-specific rules were the issue.
    match /trip_settings/{settingsId} {
      allow read, write: if true;
      
      match /{allPaths=**} {
        allow read, write: if true;
      }
    }

    match /itineraries/{planId} {
      allow read: if true;
      allow write: if false; // Only admin via cloud console or future panel
    }
  }
}
